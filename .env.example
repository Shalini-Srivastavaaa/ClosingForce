# ClosingForce - Environment Configuration
#
# 1. Copy this file to .env
# 2. Add your actual Gemini API key below
#
# Get a free Gemini API key:
#   https://aistudio.google.com/app/apikey
#
# Free tier (Gemini Flash) has generous limits for personal / demo use.

# === Google Gemini (recommended) ===
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite   # Best current free tier choice (budget-friendly + higher capacity)

# === Optional / Legacy (Ollama) ===
# OLLAMA_MODEL=qwen2.5:7b

# === Shared settings ===
TEMPERATURE=0.0
